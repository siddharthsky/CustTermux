<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="16dp"/>
            <solid android:color="#3A1F1F"/> <stroke
            android:width="4dp"
            android:color="#FFD700"/> </shape>
    </item>

    <item>
        <ripple android:color="#33FF5252">
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="16dp"/>
                    <gradient
                        android:startColor="#2A1A1A"
                        android:endColor="#3A1F1F"
                        android:angle="90"/>
                    <stroke
                        android:width="1dp"
                        android:color="#541717"/> </shape>
            </item>
        </ripple>
    </item>

</selector>
