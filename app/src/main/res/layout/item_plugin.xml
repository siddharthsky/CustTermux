<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/tv_plugin_card_bg"
    android:orientation="vertical"
    android:padding="12dp"
    android:layout_marginBottom="10dp">

    <TextView
        android:id="@+id/pluginName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#fff"
        android:textSize="16sp"/>

    <TextView
        android:id="@+id/pluginStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Stopped"
        android:textColor="#aaa"/>

    <TextView
        android:id="@+id/pluginPlaylist"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:focusable="true"
        android:text="http://localhost:111/playlist.m3u"
        android:textColor="#38bdf8"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical">

        <!-- LEFT SIDE BUTTONS -->
        <Button
            android:id="@+id/loginBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/tv_plugin_item_btns"
            android:padding="10dp"
            android:layout_marginEnd="8dp"
            android:focusable="true"
            android:visibility="gone"
            android:text="Login" />

        <!-- Add more buttons here later -->
        <!-- Example -->
        <!--
        <Button
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Extra"
            android:layout_marginEnd="8dp"/>
        -->

        <!-- SPACER (pushes Remove to right) -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- RIGHT SIDE BUTTON -->
        <Button
            android:id="@+id/deleteBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/tv_plugin_item_btns"
            android:padding="10dp"
            android:focusable="true"
            android:text="🗑️ Remove" />

    </LinearLayout>

</LinearLayout>
