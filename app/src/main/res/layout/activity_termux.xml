<com.termux.app.terminal.TermuxActivityRootView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/activity_termux_root_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A1A1B"
    android:fitsSystemWindows="true">

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:overScrollMode="never"
        android:scrollbars="none"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingVertical="4dp">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/button1"
                android:layout_width="85dp"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:background="@drawable/button_card"
                android:focusable="true"
                android:gravity="center"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:drawableTop="@drawable/tx_m_minimize"
                android:drawableTint="#FFFFFF"
                android:drawablePadding="2dp"
                android:text="Min"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:tooltipText="Minimize" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/button2"
                android:layout_width="85dp"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:background="@drawable/button_card"
                android:gravity="center"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:drawableTop="@drawable/tx_m_rerun3"
                android:drawableTint="#B2E2D2"
                android:drawablePadding="2dp"
                android:text="ReRun"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:tooltipText="Restart Server" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/button_update"
                android:layout_width="85dp"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:background="@drawable/button_card"
                android:gravity="center"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:drawableTop="@drawable/tx_star"
                android:drawableTint="#FFD700"
                android:drawablePadding="2dp"
                android:text="Update"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:visibility="gone"
                android:tooltipText="Update App" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/buttonHana"
                android:layout_width="85dp"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:background="@drawable/button_card"
                android:gravity="center"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:drawableTop="@drawable/tx_m_tv"
                android:drawableTint="#FFD1DC"
                android:drawablePadding="2dp"
                android:text="Player"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:tooltipText="Watch Channels" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/button5"
                android:layout_width="85dp"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:background="@drawable/button_card"
                android:gravity="center"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:drawableTop="@drawable/tx_m_plugin"
                android:drawableTint="#AFDFE4"
                android:drawablePadding="2dp"
                android:text="Plugins"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:tooltipText="Manage plugins" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/button3"
                android:layout_width="85dp"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:background="@drawable/button_card"
                android:gravity="center"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:drawableTop="@drawable/tx_m_more"
                android:drawableTint="#FFFFFF"
                android:drawablePadding="2dp"
                android:text="More"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:tooltipText="Extra Options" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/button4"
                android:layout_width="85dp"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:background="@drawable/button_card_exit"
                android:gravity="center"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:drawableTop="@drawable/tx_m_exit"
                android:drawableTint="#FFFFFF"
                android:drawablePadding="2dp"
                android:text="Exit"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:tooltipText="Exit App" />

        </LinearLayout>
    </HorizontalScrollView>

    <LinearLayout
        android:id="@+id/update_progress_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/update_status_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Downloading..."
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:gravity="center"/>

        <ProgressBar
            android:id="@+id/update_progress_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:max="100"
            android:progress="0"/>
    </LinearLayout>

    <!-- Restart Banner -->
    <TextView
        android:id="@+id/restartBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#EF4444"
        android:text="Action Required: Please restart app after plugin installation."
        android:textColor="#FFFFFF"
        android:padding="10dp"
        android:gravity="center"
        android:textSize="12sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp"
        android:gravity="center">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_margin="4dp"
            android:background="@drawable/status_card">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="IP ADDRESS"
                android:textColor="#BBBBBB"
                android:textSize="10sp"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/ip_address"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Detecting..."
                android:textColor="#FF9800"
                android:textStyle="bold"
                android:textSize="13sp"
                android:maxLines="1" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_margin="4dp"
            android:background="@drawable/status_card">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="STORAGE"
                android:textColor="#BBBBBB"
                android:textSize="10sp"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/storage_permission_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Checking..."
                android:textColor="#FF5252"
                android:textStyle="bold"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_margin="4dp"
            android:background="@drawable/status_card">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OVERLAY"
                android:textColor="#BBBBBB"
                android:textSize="10sp"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/overlay_permission_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Checking..."
                android:textColor="#FF5252"
                android:textStyle="bold"
                android:textSize="13sp" />
        </LinearLayout>

    </LinearLayout>

    <RelativeLayout
        android:id="@+id/activity_termux_root_relative_layout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginHorizontal="3dp"
        android:layout_marginVertical="0dp"
        android:orientation="vertical">

        <androidx.drawerlayout.widget.DrawerLayout
            android:id="@+id/drawer_layout"
            android:layout_width="match_parent"
            android:layout_alignParentTop="true"
            android:layout_above="@+id/terminal_toolbar_view_pager"
            android:layout_height="match_parent">

            <com.termux.view.TerminalView
                android:id="@+id/terminal_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:defaultFocusHighlightEnabled="false"
                android:focusableInTouchMode="false"
                android:scrollbarThumbVertical="@drawable/terminal_scroll_shape"
                android:scrollbars="vertical"
                android:background="@drawable/terminal_bg_final"
                tools:ignore="UnusedAttribute" />

            <LinearLayout
                android:id="@+id/left_drawer"
                android:layout_width="240dp"
                android:layout_height="match_parent"
                android:layout_gravity="start"
                android:choiceMode="singleChoice"
                android:divider="@android:color/transparent"
                android:dividerHeight="0dp"
                android:descendantFocusability="blocksDescendants"
                android:orientation="vertical"
                android:background="?attr/termuxActivityDrawerBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <ImageButton
                        android:id="@+id/settings_button"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_settings"
                        android:background="@null"
                        android:contentDescription="@string/action_open_settings"
                        app:tint="?attr/termuxActivityDrawerImageTint" />
                </LinearLayout>

                <ListView
                    android:id="@+id/terminal_sessions_list"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_gravity="top"
                    android:layout_weight="1"
                    android:choiceMode="singleChoice"
                    android:longClickable="true" />

                <LinearLayout
                    style="?android:attr/buttonBarStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/toggle_keyboard_button"
                        style="?android:attr/buttonBarButtonStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/action_toggle_soft_keyboard" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/new_session_button"
                        style="?android:attr/buttonBarButtonStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/action_new_session" />
                </LinearLayout>
            </LinearLayout>

        </androidx.drawerlayout.widget.DrawerLayout>

        <androidx.viewpager.widget.ViewPager
            android:id="@+id/terminal_toolbar_view_pager"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="37.5dp"
            android:background="#1A1A1B"
            android:layout_alignParentBottom="true" />

    </RelativeLayout>

    <View
        android:id="@+id/activity_termux_bottom_space_view"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@android:color/transparent" />

</com.termux.app.terminal.TermuxActivityRootView>
