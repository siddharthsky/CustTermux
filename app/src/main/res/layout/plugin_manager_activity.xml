<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0F172A">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#111827"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="4dp"> <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Plugin Manager"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold" />

        <Button
            android:id="@+id/btnAdd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:text="+ Add Plugin"
            android:background="@drawable/tv_plugin_add_btn"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp"
            android:focusable="true" />

        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:background="@drawable/img_btn_selector"
            android:contentDescription="More"
            android:scaleType="centerInside"
            android:focusable="true"
            android:src="@drawable/tx_more" />

    </LinearLayout>

    <!-- Plugin List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/pluginList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp"
        android:clipToPadding="false" />

</LinearLayout>
