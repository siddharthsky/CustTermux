<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A1A1B">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#1A1A1B"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Plugin Manager"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnAdd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:text="+ Add Plugin"
            android:background="@drawable/tv_plugin_add_btn_sk"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp"
            android:focusable="true" />

        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:background="@drawable/img_btn_selector"
            android:contentDescription="More"
            android:scaleType="centerInside"
            android:focusable="true"
            android:src="@drawable/tx_more" />

    </LinearLayout>

    <TextView
        android:id="@+id/restartBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#EF4444"
        android:text="Action Required: Please restart the server for changes to take effect."
        android:textColor="#FFFFFF"
        android:padding="12dp"
        android:gravity="center"
        android:textSize="12sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/pluginList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp"
        android:clipToPadding="false" />

    <LinearLayout
        android:id="@+id/emptyStateContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No plugins found."
            android:textColor="#CCCCCC"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add plugins to get started. You can find plugin codes at:"
            android:textColor="#999999"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/repoLinkText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="siddharthsky.github.io/ctx-plugins"
            android:textColor="#3B82F6"
            android:textSize="14sp"
            android:padding="8dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

</LinearLayout>
